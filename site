  <!-- Application script (encapsulated) -->
  <script>
  (function () {
    'use strict';

    // -------------------------
    // Default configuration
    // -------------------------
    const defaultConfig = {
      hero_title: 'Você é bem-vindo aqui',
      hero_subtitle: 'Um lugar para encontrar fé, esperança e comunidade',
      whatsapp_number: '45999424023', // note: normalized digits only (demo)
      church_address: 'Rua Presidente Bernardes, 2476, Centro\nCascavel - Paraná. CEP 85810-130',
      sunday_service: '19h30',
      wednesday_service: '19h30',
      saturday_service: '09h30 Escola Bíblica / 10h30 Culto',
      google_maps_url: 'https://maps.app.goo.gl/cozHDkkmZXE9Nh1d8',
      background_color: '#003366',
      accent_color: '#D4A84B',
      text_color: '#1F2937',
      surface_color: '#FDF8F3',
      button_color: '#25D366',
      event1_title: 'Culto Especial de Batismo',
      event1_desc: 'Celebração para novos membros da nossa família',
      event1_date: 'Em breve',
      event2_title: 'Encontro de Casais',
      event2_desc: 'Fortalecendo famílias através da Palavra',
      event2_date: 'Mensal',
      event3_title: 'Reunião de Jovens',
      event3_desc: 'Comunhão e estudo para a juventude',
      event3_date: 'Semanal'
    };

    // Use localStorage config (persisted from admin) if available
    const storedConfig = (function () {
      try {
        const raw = localStorage.getItem('iap_config_v1');
        return raw ? JSON.parse(raw) : null;
      } catch (e) {
        console.warn('Falha ao ler config do localStorage', e);
        return null;
      }
    })();

    const config = Object.assign({}, defaultConfig, storedConfig || {});

    // -------------------------
    // Utilities: sanitization and safe DOM updates
    // -------------------------
    function sanitizeText(input) {
      // Basic sanitization: strip angle brackets to reduce XSS risk.
      // For production use a proven sanitizer like DOMPurify on the server or bundled into the app.
      if (input == null) return '';
      return String(input).replace(/[<>]/g, '');
    }

    function setSafeAddress(element, address) {
      if (!element) return;
      while (element.firstChild) element.removeChild(element.firstChild);
      if (!address) return;
      const lines = String(address).split(/\r?\n/);
      lines.forEach((line, idx) => {
        element.appendChild(document.createTextNode(line));
        if (idx < lines.length - 1) element.appendChild(document.createElement('br'));
      });
    }

    function cacheId(id) {
      const el = document.getElementById(id);
      if (!el) console.warn('Elemento não encontrado:', id);
      return el;
    }

    // -------------------------
    // WhatsApp helpers (normalize country code, produce wa.me link)
    // -------------------------
    function normalizeWhatsAppNumber(raw) {
      if (!raw) return '';
      const digits = String(raw).replace(/\D/g, '');
      // If already has country code (e.g., starts with 55 for BR), return as-is
      if (/^55\d+$/.test(digits)) return digits;
      // If Brazilian 10 or 11 digits, prefix with 55
      if (digits.length === 10 || digits.length === 11) return '55' + digits;
      // Unknown format: return digits (may produce invalid link)
      return digits;
    }

    function getWhatsAppUrl(number, message = '') {
      const normalized = normalizeWhatsAppNumber(number || config.whatsapp_number || defaultConfig.whatsapp_number);
      if (!normalized) return '#';
      const encodedMessage = message ? '?text=' + encodeURIComponent(message) : '';
      // use https://wa.me/<number> format
      return `https://wa.me/${normalized}${encodedMessage}`;
    }

    // -------------------------
    // Update links and UI based on config
    // -------------------------
    function updateWhatsAppLinks(cfg) {
      const number = cfg.whatsapp_number || defaultConfig.whatsapp_number;

      const safeNumber = normalizeWhatsAppNumber(number);
      // Update hero buttons (these are anchors; we don't open in new tab to preserve user flow)
      const map = [
        ['btn-conhecer', getWhatsAppUrl(safeNumber, 'Olá! Gostaria de conhecer a Igreja Adventista da Promessa.')],
        ['btn-batizar', getWhatsAppUrl(safeNumber, 'Olá! Tenho interesse em me batizar.')],
        ['btn-oracao', getWhatsAppUrl(safeNumber, 'Olá! Preciso de oração.')],
        ['btn-ministerio', getWhatsAppUrl(safeNumber, 'Olá! Gostaria de participar de um ministério.')],
        ['btn-whatsapp-main', getWhatsAppUrl(safeNumber, 'Olá! Vim pelo site da igreja.')],
        ['btn-batizar-contact', getWhatsAppUrl(safeNumber, 'Olá! Tenho interesse em me batizar.')],
        ['btn-oracao-contact', getWhatsAppUrl(safeNumber, 'Olá! Preciso de oração.')],
        ['footer-whatsapp', getWhatsAppUrl(safeNumber)],
        ['floating-whatsapp', getWhatsAppUrl(safeNumber, 'Olá! Vim pelo site da igreja.')]
      ];
      map.forEach(([id, url]) => {
        const el = cacheId(id);
        if (el) {
          el.setAttribute('href', url);
          // If it's intended to open in new tab, add rel attributes. For WhatsApp we keep default behavior.
        }
      });
    }

    function applyConfigToDom(cfg) {
      // Hero
      const heroTitle = cacheId('hero-title');
      const heroSubtitle = cacheId('hero-subtitle');
      if (heroTitle) heroTitle.textContent = sanitizeText(cfg.hero_title || defaultConfig.hero_title);
      if (heroSubtitle) heroSubtitle.textContent = sanitizeText(cfg.hero_subtitle || defaultConfig.hero_subtitle);

      // Address (safe)
      const addrEl = cacheId('church-address');
      if (addrEl) setSafeAddress(addrEl, cfg.church_address || defaultConfig.church_address);

      // Service times
      const sundayTime = cacheId('sunday-time');
      const wednesdayTime = cacheId('wednesday-time');
      const saturdayTime = cacheId('saturday-time');
      const sundayServiceInfo = cacheId('sunday-service-info');
      const wedServiceInfo = cacheId('wednesday-service-info');
      const satServiceInfo = cacheId('saturday-service-info');

      if (sundayTime) sundayTime.textContent = sanitizeText(cfg.sunday_service || defaultConfig.sunday_service);
      if (wednesdayTime) wednesdayTime.textContent = sanitizeText(cfg.wednesday_service || defaultConfig.wednesday_service);
      if (saturdayTime) saturdayTime.textContent = sanitizeText(cfg.saturday_service || defaultConfig.saturday_service);

      if (sundayServiceInfo) sundayServiceInfo.textContent = sanitizeText(cfg.sunday_service || defaultConfig.sunday_service);
      if (wedServiceInfo) wedServiceInfo.textContent = sanitizeText(cfg.wednesday_service || defaultConfig.wednesday_service);
      if (satServiceInfo) satServiceInfo.textContent = sanitizeText(cfg.saturday_service || defaultConfig.saturday_service);

      // Maps URL
      const mapsButton = cacheId('maps-button');
      if (mapsButton) {
        mapsButton.setAttribute('href', cfg.google_maps_url || defaultConfig.google_maps_url);
        mapsButton.setAttribute('rel', 'noopener noreferrer');
        mapsButton.setAttribute('target', '_blank');
      }

      // Events
      const events = [
        { title: 'event1-title', desc: 'event1-desc', date: 'event1-date', key: 'event1' },
        { title: 'event2-title', desc: 'event2-desc', date: 'event2-date', key: 'event2' },
        { title: 'event3-title', desc: 'event3-desc', date: 'event3-date', key: 'event3' }
      ];
      events.forEach((ev, idx) => {
        const titleEl = cacheId(ev.title);
        const descEl = cacheId(ev.desc);
        const dateEl = cacheId(ev.date);
        const keyTitle = cfg[ev.key + '_title'] || defaultConfig[ev.key + '_title'];
        const keyDesc = cfg[ev.key + '_desc'] || defaultConfig[ev.key + '_desc'];
        const keyDate = cfg[ev.key + '_date'] || defaultConfig[ev.key + '_date'];

        if (titleEl) titleEl.textContent = sanitizeText(keyTitle);
        if (descEl) descEl.textContent = sanitizeText(keyDesc);
        if (dateEl) dateEl.textContent = sanitizeText(keyDate);
      });

      // Update WhatsApp links
      updateWhatsAppLinks(cfg);
    }

    // Initial render
    applyConfigToDom(config);

    // Expose an onConfigChange to the element SDK (if present) while keeping scope private
    function onConfigChange(newConfig) {
      Object.assign(config, newConfig || {});
      // Persist to localStorage so admin edits survive refresh
      try {
        localStorage.setItem('iap_config_v1', JSON.stringify(config));
      } catch (e) {
        console.warn('Não foi possível salvar config no localStorage', e);
      }
      applyConfigToDom(config);
      // If element SDK present and supports setConfig, keep it in sync:
      if (window.elementSdk && typeof window.elementSdk.setConfig === 'function') {
        try {
          window.elementSdk.setConfig(config);
        } catch (e) {
          console.warn('elementSdk.setConfig falhou', e);
        }
      }
    }

    // If SDK exists, initialize it with our onConfigChange and map functions
    if (window.elementSdk && typeof window.elementSdk.init === 'function') {
      try {
        window.elementSdk.init({
          defaultConfig: defaultConfig,
          onConfigChange: onConfigChange,
          mapToCapabilities: (c) => ({
            recolorables: [
              {
                get: () => c.background_color || defaultConfig.background_color,
                set: (value) => {
                  c.background_color = value;
                  window.elementSdk.setConfig({ background_color: value });
                }
              },
              {
                get: () => c.surface_color || defaultConfig.surface_color,
                set: (value) => {
                  c.surface_color = value;
                  window.elementSdk.setConfig({ surface_color: value });
                }
              },
              {
                get: () => c.text_color || defaultConfig.text_color,
                set: (value) => {
                  c.text_color = value;
                  window.elementSdk.setConfig({ text_color: value });
                }
              },
              {
                get: () => c.accent_color || defaultConfig.accent_color,
                set: (value) => {
                  c.accent_color = value;
                  window.elementSdk.setConfig({ accent_color: value });
                }
              },
              {
                get: () => c.button_color || defaultConfig.button_color,
                set: (value) => {
                  c.button_color = value;
                  window.elementSdk.setConfig({ button_color: value });
                }
              }
            ],
            borderables: [],
            fontEditable: undefined,
            fontSizeable: undefined
          }),
          mapToEditPanelValues: (c) => new Map([
            ['hero_title', c.hero_title || defaultConfig.hero_title],
            ['hero_subtitle', c.hero_subtitle || defaultConfig.hero_subtitle],
            ['whatsapp_number', c.whatsapp_number || defaultConfig.whatsapp_number],
            ['church_address', c.church_address || defaultConfig.church_address],
            ['sunday_service', c.sunday_service || defaultConfig.sunday_service],
            ['wednesday_service', c.wednesday_service || defaultConfig.wednesday_service],
            ['saturday_service', c.saturday_service || defaultConfig.saturday_service],
            ['google_maps_url', c.google_maps_url || defaultConfig.google_maps_url],
            ['event1_title', c.event1_title || defaultConfig.event1_title],
            ['event1_desc', c.event1_desc || defaultConfig.event1_desc],
            ['event1_date', c.event1_date || defaultConfig.event1_date],
            ['event2_title', c.event2_title || defaultConfig.event2_title],
            ['event2_desc', c.event2_desc || defaultConfig.event2_desc],
            ['event2_date', c.event2_date || defaultConfig.event2_date],
            ['event3_title', c.event3_title || defaultConfig.event3_title],
            ['event3_desc', c.event3_desc || defaultConfig.event3_desc],
            ['event3_date', c.event3_date || defaultConfig.event3_date]
          ])
        });
      } catch (e) {
        console.warn('Erro inicializando elementSdk', e);
        // fallback to local config already applied above
      }
    }

    // -------------------------
    // Mobile menu accessibility improvements (aria-expanded, trap focus, ESC)
    // -------------------------
    (function setupMobileMenu() {
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const closeMenuBtn = document.getElementById('close-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuOverlay = document.getElementById('menu-overlay');

      if (!mobileMenuBtn || !mobileMenu || !menuOverlay) return;

      let open = false;

      function openMenu() {
        mobileMenu.classList.add('open');
        menuOverlay.classList.remove('hidden');
        menuOverlay.classList.add('block');
        document.body.style.overflow = 'hidden';
        mobileMenuBtn.setAttribute('aria-expanded', 'true');
        mobileMenu.setAttribute('aria-hidden', 'false');
        open = true;
        // focus first focusable
        const focusable = mobileMenu.querySelectorAll('a, button, input, [tabindex]:not([tabindex="-1"])');
        if (focusable.length) focusable[0].focus();
        document.addEventListener('keydown', onKeyDown);
      }

      function closeMenu() {
        mobileMenu.classList.remove('open');
        menuOverlay.classList.add('hidden');
        document.body.style.overflow = '';
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        open = false;
        mobileMenuBtn.focus();
        document.removeEventListener('keydown', onKeyDown);
      }

      function onKeyDown(e) {
        if (e.key === 'Escape') {
          closeMenu();
        }
        if (e.key === 'Tab') {
          // basic focus trap
          const focusable = Array.from(mobileMenu.querySelectorAll('a, button, input, [tabindex]:not([tabindex="-1"])'))
            .filter(el => el.offsetParent !== null);
          if (focusable.length === 0) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }

      mobileMenuBtn.addEventListener('click', () => { if (open) closeMenu(); else openMenu(); });
      closeMenuBtn && closeMenuBtn.addEventListener('click', closeMenu);
      menuOverlay.addEventListener('click', closeMenu);

      // Close menu when any mobile link clicked
      mobileMenu.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
    })();

    // -------------------------
    // Admin panel: client-side demo for editing events
    // -------------------------
    (function setupAdminPanel() {
      const adminBtn = document.getElementById('admin-btn');
      const overlay = document.getElementById('admin-modal-overlay');
      const loginSection = document.getElementById('admin-login');
      const panelSection = document.getElementById('admin-panel');
      const loginBtn = document.getElementById('admin-login-btn');
      const cancelBtn = document.getElementById('admin-cancel-btn');
      const passwordInput = document.getElementById('admin-password');

      const EVENT_KEYS = ['event1', 'event2', 'event3'];

      // Inputs
      const inputs = {
        'event1_title': document.getElementById('event1-title-input'),
        'event1_desc': document.getElementById('event1-desc-input'),
        'event1_date': document.getElementById('event1-date-input'),
        'event2_title': document.getElementById('event2-title-input'),
        'event2_desc': document.getElementById('event2-desc-input'),
        'event2_date': document.getElementById('event2-date-input'),
        'event3_title': document.getElementById('event3-title-input'),
        'event3_desc': document.getElementById('event3-desc-input'),
        'event3_date': document.getElementById('event3-date-input')
      };

      // Demo password: strongly recommend replacing this with real authentication.
      const DEMO_ADMIN_PASSWORD = 'changeme'; // CHANGE THIS for production

      function openOverlay() {
        if (!overlay) return;
        overlay.classList.add('open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        passwordInput && passwordInput.focus();
      }

      function closeOverlay() {
        if (!overlay) return;
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        loginSection.style.display = '';
        panelSection.style.display = 'none';
        // clear password
        if (passwordInput) passwordInput.value = '';
      }

      function showPanel() {
        loginSection.style.display = 'none';
        panelSection.style.display = '';
        // populate inputs with current config values
        EVENT_KEYS.forEach((k, idx) => {
          const base = k;
          const titleKey = base + '_title';
          const descKey = base + '_desc';
          const dateKey = base + '_date';
          if (inputs[titleKey]) inputs[titleKey].value = config[titleKey] || defaultConfig[titleKey] || '';
          if (inputs[descKey]) inputs[descKey].value = config[descKey] || defaultConfig[descKey] || '';
          if (inputs[dateKey]) inputs[dateKey].value = config[dateKey] || defaultConfig[dateKey] || '';
        });
      }

      if (adminBtn) {
        adminBtn.addEventListener('click', openOverlay);
      }
      if (cancelBtn) {
        cancelBtn.addEventListener('click', closeOverlay);
      }

      // Login flow
      if (loginBtn) {
        loginBtn.addEventListener('click', function () {
          const pass = passwordInput ? passwordInput.value : '';
          if (!pass) {
            alert('Por favor insira a senha administrativa.');
            return;
          }
          // Simple check (insecure): in production use server-side auth.
          if (pass === DEMO_ADMIN_PASSWORD) {
            showPanel();
          } else {
            alert('Senha incorreta. Em produção, implemente autenticação segura.');
          }
        });
      }

      // Save handler
      const saveBtn = document.getElementById('admin-save-btn');
      if (saveBtn) {
        saveBtn.addEventListener('click', function () {
          // Read inputs, sanitize, update config object, persist and re-render
          EVENT_KEYS.forEach(k => {
            const titleKey = k + '_title';
            const descKey = k + '_desc';
            const dateKey = k + '_date';
            if (inputs[titleKey]) config[titleKey] = sanitizeText(inputs[titleKey].value) || defaultConfig[titleKey];
            if (inputs[descKey]) config[descKey] = sanitizeText(inputs[descKey].value) || defaultConfig[descKey];
            if (inputs[dateKey]) config[dateKey] = sanitizeText(inputs[dateKey].value) || defaultConfig[dateKey];
          });

          // Persist to localStorage
          try {
            localStorage.setItem('iap_config_v1', JSON.stringify(config));
          } catch (e) {
            console.warn('Falha ao salvar config', e);
          }

          // Apply to DOM
          applyConfigToDom(config);

          // If elementSdk available, update it
          if (window.elementSdk && typeof window.elementSdk.setConfig === 'function') {
            try {
              window.elementSdk.setConfig(config);
            } catch (e) {
              console.warn('elementSdk.setConfig falhou', e);
            }
          }

          alert('Eventos atualizados com sucesso!');
        });
      }

      // Logout / close from admin panel
      const logoutBtn = document.getElementById('admin-logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function () {
          closeOverlay();
        });
      }

      // Close overlay on outside click
      overlay && overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeOverlay();
      });

      // Prevent overlay from being keyboard-inaccessible
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && overlay && overlay.classList.contains('open')) {
          closeOverlay();
        }
      });
    })();

    // -------------------------
    // Enhance external links to include rel="noopener noreferrer" (safety)
    // -------------------------
    (function secureExternalLinks() {
      const anchors = document.querySelectorAll('a[target="_blank"]');
      anchors.forEach(a => {
        if (!a.hasAttribute('rel')) a.setAttribute('rel', 'noopener noreferrer');
      });
    })();

    // Expose onConfigChange to window for external SDKs that expect it
    window.__iap_onConfigChange = onConfigChange;

    // Ensure initial WhatsApp links and other dynamic links updated
    updateWhatsAppLinks(config);

  })();
